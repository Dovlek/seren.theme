<window type="dialog">
    <defaultcontrol>2</defaultcontrol>
    <coordinates>
        <left>0</left>
        <top>0</top>
    </coordinates>
    <controls>
        <!-- Background Texture -->
        <control type="image">
            <texture>$INFO[Window().Property(texture.white)]</texture>
            <colordiffuse>FF000000</colordiffuse>
        </control>

        <!-- Background -->
        <control type="image">
            <top>0</top>
            <left>0</left>
            <width>1920</width>
            <height>1080</height>
            <texture background="true">$INFO[Window().Property(item.art.fanart)]</texture>
        </control>

        <control type="image">
            <top>0</top>
            <left>0</left>
            <width>1920</width>
            <height>1080</height>
            <texture background="true">$INFO[Window().Property(texture.white)]</texture>
            <colordiffuse>CC000000</colordiffuse>
        </control>

        <!-- Grouplist Texture -->
        <control type="image">
            <visible>true</visible>
            <left>0</left>
            <top>150</top>
            <width>100%</width>
            <height>1000</height>
            <border>5</border>
            <texture>$INFO[Window().Property(texture.white)]</texture>
            <colordiffuse>CC222222</colordiffuse>
        </control>

        <!-- Sources List -->
        <control type="list" id="1000">
            <viewtype label="Sources">list</viewtype>
            <onright>2000</onright>
            <onup>2000</onup>
            <left>50</left>
            <top>200</top>
            <width>1300</width>
            <height>890</height>
            <orientation>vertical</orientation>
            <focusposition>1</focusposition>
            <itemlayout height="120">
                <control type="label">
                    <top>5</top>
                    <left>10</left>
                    <width>1400</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>66FFFFFF</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                    <label>[B][UPPERCASE]$INFO[ListItem.Label][/UPPERCASE][/B]</label>
                </control>
                <control type="label">
                    <top>50</top>
                    <left>10</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <align>left</align>
                    <label>Size: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(size)][/COLOR]
                    </label>
                </control>
                <control type="label">
                    <top>50</top>
                    <left>400</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <label>Provider: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(provider)][/COLOR]
                    </label>
                </control>
                <control type="label">
                    <top>50</top>
                    <left>800</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <label>Type: [UPPERCASE][COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(type)][/COLOR][/UPPERCASE]
                    </label>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>10</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <align>left</align>
                    <font>font12</font>
                    <label>Quality: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(quality)][/COLOR]
                    </label>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>400</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <align>left</align>
                    <label>Debrid: [UPPERCASE][COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(debrid_provider)][/COLOR][/UPPERCASE]</label>
                    <visible>!String.Contains(ListItem.Property(debrid_provider),USENET)</visible>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>400</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <align>left</align>
                    <label>Hoster:     [UPPERCASE][COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(debrid_provider)][/COLOR][/UPPERCASE]</label>
                    <visible>String.Contains(ListItem.Property(debrid_provider),USENET)</visible>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>800</left>
                    <width>350</width>
                    <height>50</height>
                    <textcolor>AAFFFFFF</textcolor>
                    <font>font12</font>
                    <label>Info: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(info_text_piped_color)][/COLOR]
                    </label>
                </control>
            </itemlayout>

            <focusedlayout height="120">
                <control type="image">
                    <width>100%</width>
                    <height>100%</height>
                    <texture>$INFO[Window().Property(texture.white)]</texture>
                    <colordiffuse>FFFFFFFF</colordiffuse>
                </control>
                <control type="label">
                    <top>5</top>
                    <left>10</left>
                    <width>1400</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>FF000000</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                    <label>[B][UPPERCASE]$INFO[ListItem.Label][/UPPERCASE][/B]</label>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>400</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>FF000000</textcolor>
                    <align>left</align>
                    <label>Debrid: [UPPERCASE][COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(debrid_provider)][/COLOR][/UPPERCASE]</label>
                    <visible>!String.Contains(ListItem.Property(debrid_provider),USENET)</visible>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>400</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <align>left</align>
                    <label>Hoster:     [UPPERCASE][COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(debrid_provider)][/COLOR][/UPPERCASE]</label>
                    <visible>String.Contains(ListItem.Property(debrid_provider),USENET)</visible>
                </control>
                <control type="label">
                    <top>50</top>
                    <left>10</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>FF000000</textcolor>
                    <align>left</align>
                    <label>Size: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(size)][/COLOR]
                    </label>
                </control>
                <control type="label">
                    <top>50</top>
                    <left>400</left>
                    <width>350</width>
                    <height>50</height>
                    <textcolor>FF000000</textcolor>
                    <font>font12</font>
                    <label>Provider: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(provider)][/COLOR]
                    </label>
                </control>
                <control type="label">
                    <top>50</top>
                    <left>800</left>
                    <width>350</width>
                    <height>50</height>
                    <textcolor>FF000000</textcolor>
                    <font>font12</font>
                    <label>Type: [UPPERCASE][COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(type)][/COLOR][/UPPERCASE]
                    </label>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>10</left>
                    <width>350</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>FF000000</textcolor>
                    <align>left</align>
                    <label>Quality: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(quality)][/COLOR]
                    </label>
                </control>
                <control type="label">
                    <top>80</top>
                    <left>800</left>
                    <width>350</width>
                    <height>50</height>
                    <textcolor>FF000000</textcolor>
                    <font>font12</font>
                    <label>Info: [COLOR $INFO[Window().Property(settings.color)]]$INFO[ListItem.Property(info_text_piped_color)][/COLOR]
                    </label>
                </control>
            </focusedlayout>
        </control>

        <!-- Side Info - Poster -->
        <control type="image">
            <top>200</top>
            <left>1450</left>
            <width>400</width>
            <height>600</height>
            <texture>$INFO[Window().Property(item.art.poster)]</texture>
        </control>

        <!-- Side Info - Movie (no season) -->
        <control type="group">
            <top>810</top>
            <left>1450</left>
            <visible>String.IsEmpty(Window().Property(item.info.season))</visible>
            <control type="label">
                <top>0</top>
                <width>400</width>
                <font>font12</font>
                <textcolor>AAFFFFFF</textcolor>
                <align>center</align>
                <label>[COLOR $INFO[Window().Property(settings.color)]]$INFO[Window().Property(item.info.title)][/COLOR]</label>
            </control>
            <control type="label">
                <top>33</top>
                <width>400</width>
                <font>font10</font>
                <textcolor>AAFFFFFF</textcolor>
                <align>center</align>
                <label>Year: [COLOR $INFO[Window().Property(settings.color)]]$INFO[Window().Property(item.info.year)][/COLOR] | Rating: [COLOR $INFO[Window().Property(settings.color)]]$INFO[Window().Property(item.info.rating)][/COLOR]</label>
            </control>
            <control type="textbox">
                <top>63</top>
                <left>-25</left>
                <height>185</height>
                <width>450</width>
                <font>font10</font>
                <textcolor>AAFFFFFF</textcolor>
                <autoscroll start="2000" delay="3000" time="2000">true</autoscroll>
                <label>$INFO[Window().Property(item.info.plot)]</label>
            </control>
        </control>

        <!-- Side Info - TV episode (has season) -->
        <control type="group">
            <top>810</top>
            <left>1450</left>
            <visible>!String.IsEmpty(Window().Property(item.info.season))</visible>
            <control type="label">
                <top>0</top>
                <width>400</width>
                <font>font12</font>
                <textcolor>AAFFFFFF</textcolor>
                <align>center</align>
                <label>[COLOR $INFO[Window().Property(settings.color)]]$INFO[Window().Property(item.info.title)][/COLOR]</label>
            </control>
            <control type="label">
                <top>33</top>
                <width>400</width>
                <font>font10</font>
                <textcolor>AAFFFFFF</textcolor>
                <align>center</align>
                <label>Season: [COLOR $INFO[Window().Property(settings.color)]]$INFO[Window().Property(item.info.season)][/COLOR] | Episode: [COLOR $INFO[Window().Property(settings.color)]]$INFO[Window().Property(item.info.episode)][/COLOR]</label>
            </control>
            <control type="label">
                <top>63</top>
                <width>400</width>
                <font>font10</font>
                <textcolor>AAFFFFFF</textcolor>
                <align>center</align>
                <label>Aired: [COLOR $INFO[Window().Property(settings.color)]]$INFO[Window().Property(item.info.premiered)][/COLOR]</label>
            </control>
            <control type="textbox">
                <top>93</top>
                <left>-25</left>
                <height>150</height>
                <width>450</width>
                <font>font10</font>
                <textcolor>AAFFFFFF</textcolor>
                <autoscroll start="2000" delay="3000" time="2000">true</autoscroll>
                <label>$INFO[Window().Property(item.info.plot)]</label>
            </control>
        </control>

        <!-- HR -->
        <control type="image">
            <top>160</top>
            <height>1</height>
            <width>100%</width>
            <left>0</left>
            <texture>white.png</texture>
        </control>

        <!-- HR -->
        <control type="image">
            <top>0</top>
            <height>1</height>
            <width>100%</width>
            <left>0</left>
            <texture>white.png</texture>
        </control>

        <!-- Menu BG -->
        <control type="image">
            <top>0</top>
            <left>0</left>
            <width>100%</width>
            <height>160</height>
            <texture>white.png</texture>
            <colordiffuse>FF222222</colordiffuse>
        </control>

        <!-- Menu -->
        <control type="group">
            <top>90</top>
            <height>150</height>
            <width>300</width>
            <left>50</left>

            <!-- Seren Logo -->
            <control type="image" id="1001">
                <top>-45</top>
                <left>0</left>
                <width>100</width>
                <height>100</height>
                <aspectratio>keep</aspectratio>
                <texture>$INFO[Window().Property(seren.logo)]</texture>
            </control>

            <control type="label">
                <height>50</height>
                <width>auto</width>
                <top>-50</top>
                <left>130</left>
                <label>[COLOR $INFO[Window().Property(settings.color)]]Source Select[/COLOR]</label>
                <textcolor>FFFFFFFF</textcolor>
            </control>

            <control type="grouplist" id="2000">
                <height>100%</height>
                <width>700</width>
                <top>0</top>
                <right>0</right>
                <left>130</left>
                <defaultcontrol>2001</defaultcontrol>
                <ondown>1000</ondown>
                <onleft>1000</onleft>
                <orientation>horizontal</orientation>
                <control type="button" id="2001">
                    <top>0</top>
                    <width>250</width>
                    <height>50</height>
                    <font>font12</font>
                    <textcolor>FFFFFFFFF</textcolor>
                    <border>5</border>
                    <colordiffuse>FFFFFFFF</colordiffuse>
                    <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                    <texturenofocus colordiffuse="FF181818">white.png</texturenofocus>
                    <focusedcolor>FF000000</focusedcolor>
                    <label>View Uncached</label>
                    <align>center</align>
                </control>

