            <visible>true</visible>
            <left>0</left>
            <top>150</top>
            <width>100%</width>
            <height>1000</height>
            <border>5</border>
            <texture>$INFO[Window().Property(texture.white)]</texture>
            <colordiffuse>CC222222</colordiffuse>
        </control>

