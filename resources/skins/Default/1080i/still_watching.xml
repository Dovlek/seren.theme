<?xml version="1.0" encoding="UTF-8"?>
<window>
    <onload>Dialog.Close(fullscreeninfo,true)</onload>
    <onload>Dialog.Close(videoosd,true)</onload>

    <defaultcontrol always="true">3001</defaultcontrol>

    <controls>

        <!-- Top-bar background -->
        <control type="image">
            <top>0</top>
            <left>0</left>
            <width>100%</width>
            <height>210</height>
            <texture colordiffuse="CC000000">white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="cubic" easing="in"/>
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" tween="cubic" easing="in"/>
            </animation>
        </control>

        <!-- Thumbnail -->
        <control type="group">
            <top>15</top>
            <left>30</left>
            <width>320</width>
            <height>180</height>

            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="cubic" easing="in"/>
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" tween="cubic" easing="in"/>
            </animation>

            <!-- Fallback colour block -->
            <control type="image">
                <width>320</width>
                <height>180</height>
                <texture colordiffuse="FF333333">white.png</texture>
                <visible>String.IsEmpty(Window.Property(item.art.landscape)) + String.IsEmpty(Window.Property(item.art.fanart)) + String.IsEmpty(Window.Property(item.art.thumb))</visible>
            </control>

            <control type="image">
                <width>320</width>
                <height>180</height>
                <texture>$INFO[Window.Property(item.art.landscape)]</texture>
                <aspectratio>scale</aspectratio>
                <visible>!String.IsEmpty(Window.Property(item.art.landscape))</visible>
            </control>

            <control type="image">
                <width>320</width>
                <height>180</height>
                <texture>$INFO[Window.Property(item.art.fanart)]</texture>
                <aspectratio>scale</aspectratio>
                <visible>String.IsEmpty(Window.Property(item.art.landscape))</visible>
            </control>

            <control type="image">
                <width>320</width>
                <height>180</height>
                <texture>$INFO[Window.Property(item.art.thumb)]</texture>
                <aspectratio>scale</aspectratio>
                <visible>String.IsEmpty(Window.Property(item.art.landscape)) + String.IsEmpty(Window.Property(item.art.fanart))</visible>
            </control>

            <!-- Progress Bar -->
            <control type="progress" id="3014">
                <bottom>0</bottom>
                <left>0</left>
                <right>0</right>
                <height>4</height>
                <reveal>true</reveal>
                <righttexture></righttexture>
                <overlaytexture></overlaytexture>
                <lefttexture></lefttexture>
                <texturebg colordiffuse="33FFFFFF">white.png</texturebg>
                <midtexture colordiffuse="$INFO[Window.Property(settings.color)]">white.png</midtexture>
            </control>
        </control>

        <!-- Info: header, details, buttons -->
        <control type="group">
            <top>15</top>
            <left>375</left>
            <right>30</right>

            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" tween="cubic" easing="in"/>
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" tween="cubic" easing="in"/>
            </animation>

            <!-- Header -->
            <control type="label">
                <top>0</top>
                <height>52</height>
                <font>font52_title</font>
                <textcolor>ffffffff</textcolor>
                <label>$ADDON[plugin.video.seren 30559]</label>
            </control>

            <!-- Details: show | S##E## | episode title | aired | rating -->
            <control type="grouplist">
                <top>60</top>
                <height>40</height>
                <orientation>horizontal</orientation>
                <itemgap>0</itemgap>

                <control type="label">
                    <width>auto</width>
                    <height>40</height>
                    <font>font37</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <label>$INFO[Window.Property(item.info.tvshowtitle)]</label>
                    <visible>!String.IsEmpty(Window.Property(item.info.tvshowtitle))</visible>
                </control>

                <control type="label">
                    <width>auto</width>
                    <height>40</height>
                    <font>font37</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <label> | S$INFO[Window.Property(item.info.season)]E$INFO[Window.Property(item.info.episode)]</label>
                    <visible>!String.IsEmpty(Window.Property(item.info.season))</visible>
                </control>

                <control type="label">
                    <width>auto</width>
                    <height>40</height>
                    <font>font37</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <label> | $INFO[Window.Property(item.info.title)]</label>
                    <visible>!String.IsEmpty(Window.Property(item.info.title))</visible>
                </control>

                <control type="label">
                    <width>auto</width>
                    <height>40</height>
                    <font>font37</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <label> | $INFO[Window.Property(item.info.aired)]</label>
                    <visible>!String.IsEmpty(Window.Property(item.info.aired))</visible>
                </control>

                <control type="label">
                    <width>auto</width>
                    <height>40</height>
                    <font>font37</font>
                    <textcolor>AAFFFFFF</textcolor>
                    <label> | [COLOR $INFO[Window.Property(settings.color)]]★[/COLOR] $INFO[Window.Property(item.info.rating)]</label>
                    <visible>!String.IsEmpty(Window.Property(item.info.rating)) + !String.IsEqual(Window.Property(item.info.rating),0) + !String.IsEqual(Window.Property(item.info.rating),0.0)</visible>
                </control>
            </control>

            <!-- Buttons -->
            <control type="grouplist">
                <top>128</top>
                <height>56</height>
                <orientation>horizontal</orientation>
                <itemgap>10</itemgap>

                <!-- Next (Play Next) -->
                <control type="group">
                    <width>148</width>
                    <height>56</height>
                    <control type="button" id="3001">
                        <label> </label>
                        <width>148</width>
                        <height>56</height>
                        <onright>SetFocus(3003)</onright>
                        <texturefocus border="14" colordiffuse="$INFO[Window.Property(settings.color)]">button_rounded.png</texturefocus>
                        <texturenofocus border="14" colordiffuse="99000000">button_rounded.png</texturenofocus>
                        <pulseonselect>no</pulseonselect>
                    </control>
                    <control type="label">
                        <left>56</left>
                        <top>0</top>
                        <height>56</height>
                        <font>font27_title</font>
                        <textcolor>eeffffff</textcolor>
                        <aligny>center</aligny>
                        <scroll>false</scroll>
                        <label>NEXT</label>
                        <visible>Control.HasFocus(3001)</visible>
                    </control>
                    <control type="label">
                        <left>56</left>
                        <top>0</top>
                        <height>56</height>
                        <font>font27_title</font>
                        <textcolor>AAFFFFFF</textcolor>
                        <aligny>center</aligny>
                        <scroll>false</scroll>
                        <label>NEXT</label>
                        <visible>!Control.HasFocus(3001)</visible>
                    </control>
                    <control type="image">
                        <left>9</left>
                        <top>12</top>
                        <width>36</width>
                        <height>32</height>
                        <texture colordiffuse="CCffffff">btn_circle.png</texture>
                        <visible>Control.HasFocus(3001)</visible>
                    </control>
                    <control type="image">
                        <left>9</left>
                        <top>12</top>
                        <width>36</width>
                        <height>32</height>
                        <texture colordiffuse="55ffffff">btn_circle.png</texture>
                        <visible>!Control.HasFocus(3001)</visible>
                    </control>
                    <control type="image">
                        <left>16</left>
                        <top>15</top>
                        <width>26</width>
                        <height>26</height>
                        <texture colordiffuse="DD333333">btn_play.png</texture>
                    </control>
                </control>

                <!-- Stop -->
                <control type="group">
                    <width>148</width>
                    <height>56</height>
                    <control type="button" id="3003">
                        <label> </label>
                        <width>148</width>
                        <height>56</height>
                        <onleft>SetFocus(3001)</onleft>
                        <onright>SetFocus(3002)</onright>
                        <texturefocus border="14" colordiffuse="$INFO[Window.Property(settings.color)]">button_rounded.png</texturefocus>
                        <texturenofocus border="14" colordiffuse="99000000">button_rounded.png</texturenofocus>
                        <pulseonselect>no</pulseonselect>
                    </control>
                    <control type="label">
                        <left>56</left>
                        <top>0</top>
                        <height>56</height>
                        <font>font27_title</font>
                        <textcolor>eeffffff</textcolor>
                        <aligny>center</aligny>
                        <scroll>false</scroll>
                        <label>STOP</label>
                        <visible>Control.HasFocus(3003)</visible>
                    </control>
                    <control type="label">
                        <left>56</left>
                        <top>0</top>
                        <height>56</height>
                        <font>font27_title</font>
                        <textcolor>AAFFFFFF</textcolor>
                        <aligny>center</aligny>
                        <scroll>false</scroll>
                        <label>STOP</label>
                        <visible>!Control.HasFocus(3003)</visible>
                    </control>
                    <control type="image">
                        <left>9</left>
                        <top>12</top>
                        <width>36</width>
                        <height>32</height>
                        <texture colordiffuse="CCffffff">btn_circle.png</texture>
                        <visible>Control.HasFocus(3003)</visible>
                    </control>
                    <control type="image">
                        <left>9</left>
                        <top>12</top>
                        <width>36</width>
                        <height>32</height>
                        <texture colordiffuse="55ffffff">btn_circle.png</texture>
                        <visible>!Control.HasFocus(3003)</visible>
                    </control>
                    <control type="image">
                        <left>15</left>
                        <top>16</top>
                        <width>24</width>
                        <height>24</height>
                        <texture colordiffuse="DD333333">btn_stop.png</texture>
                    </control>
                </control>

                <!-- Close -->
                <control type="group">
                    <width>168</width>
                    <height>56</height>
                    <control type="button" id="3002">
                        <label> </label>
                        <width>168</width>
                        <height>56</height>
                        <onleft>SetFocus(3003)</onleft>
                        <texturefocus border="14" colordiffuse="$INFO[Window.Property(settings.color)]">button_rounded.png</texturefocus>
                        <texturenofocus border="14" colordiffuse="99000000">button_rounded.png</texturenofocus>
                        <pulseonselect>no</pulseonselect>
                    </control>
                    <control type="label">
                        <left>56</left>
                        <top>0</top>
                        <height>56</height>
                        <font>font27_title</font>
                        <textcolor>eeffffff</textcolor>
                        <aligny>center</aligny>
                        <scroll>false</scroll>
                        <label>CLOSE</label>
                        <visible>Control.HasFocus(3002)</visible>
                    </control>
                    <control type="label">
                        <left>56</left>
                        <top>0</top>
                        <height>56</height>
                        <font>font27_title</font>
                        <textcolor>AAFFFFFF</textcolor>
                        <aligny>center</aligny>
                        <scroll>false</scroll>
                        <label>CLOSE</label>
                        <visible>!Control.HasFocus(3002)</visible>
                    </control>
                    <control type="image">
                        <left>9</left>
                        <top>12</top>
                        <width>36</width>
                        <height>32</height>
                        <texture colordiffuse="CCffffff">btn_circle.png</texture>
                        <visible>Control.HasFocus(3002)</visible>
                    </control>
                    <control type="image">
                        <left>9</left>
                        <top>12</top>
                        <width>36</width>
                        <height>32</height>
                        <texture colordiffuse="55ffffff">btn_circle.png</texture>
                        <visible>!Control.HasFocus(3002)</visible>
                    </control>
                    <control type="image">
                        <left>13</left>
                        <top>14</top>
                        <width>28</width>
                        <height>28</height>
                        <texture colordiffuse="DD333333">btn_close.png</texture>
                    </control>
                </control>
            </control>
        </control>

    </controls>
</window>
